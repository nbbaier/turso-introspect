{
	"name": "turso-introspect",
	"version": "0.1.0",
	"description": "A CLI tool to introspect the database schema of a Turso/libsql database.",
	"keywords": [
		"turso",
		"libsql",
		"sqlite",
		"schema",
		"introspection",
		"cli"
	],
	"homepage": "https://github.com/nbbaier/turso-introspect#readme",
	"bugs": {
		"url": "https://github.com/nbbaier/turso-introspect/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nbbaier/turso-introspect.git"
	},
	"license": "MIT",
	"author": "Nico Baier <nico.baier@gmail.com>",
	"type": "module",
	"main": "./dist/api.js",
	"types": "./dist/api.d.ts",
	"exports": {
		".": {
			"types": "./dist/api.d.ts",
			"import": "./dist/api.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"turso-introspect": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"start": "bun run src/index.ts",
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "bun test",
		"prepublishOnly": "npm run build",
		"check": "biome check .",
		"fix": "biome check --write --unsafe .",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"@types/bun": "^1.3.11",
		"@types/node": "^25.5.0",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"@libsql/client": "^0.17.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"diff": "^8.0.4"
	},
	"overrides": {
		"ws": "^8.20.1"
	}
}
